# ============================================================
# LifeLaunch Loans — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values below.
# NEVER commit the .env file to version control.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Anthropic ───────────────────────────────────────────────
# Found in: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Server ──────────────────────────────────────────────────
PORT=3001

# ── CORS (optional) ─────────────────────────────────────────
# Comma-separated list of allowed origins.
# Leave unset (or use *) to allow all origins during development.
# Example: CORS_ORIGIN=https://lifelaunch.app
# CORS_ORIGIN=*

# ── Node environment ────────────────────────────────────────
NODE_ENV=development
